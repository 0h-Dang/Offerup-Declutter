{
  "manifest_version": 3,
  "name": "OfferUp Filter",
  "version": "1.0",
  "description": "Filters duplicate listings and financing/dealer spam from OfferUp browse pages.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://offerup.com/*"],
  "content_scripts": [
    {
      "matches": ["https://offerup.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
